{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@satvaaah/types": ["../../packages/types/src/index.ts"],
      "@satvaaah/db": ["../../packages/db/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["react-native", "@types/react"]
  },
  "include": [
    "App.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "babel.config.js",
    "metro.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".expo"
  ]
}
