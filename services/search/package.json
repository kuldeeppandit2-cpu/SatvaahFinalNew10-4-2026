{
  "name": "@satvaaah/search",
  "version": "1.0.0",
  "description": "SatvAAh search service \u2014 OpenSearch expanding ring search, taxonomy",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "start": "node dist/app.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@satvaaah/config": "workspace:*",
    "@satvaaah/db": "workspace:*",
    "@satvaaah/errors": "workspace:*",
    "@satvaaah/logger": "workspace:*",
    "@satvaaah/middleware": "workspace:*",
    "@satvaaah/types": "workspace:*",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0",
    "@opensearch-project/opensearch": "^2.3.0",
    "socket.io": "^4.6.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "redis": "^4.6.13"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "@types/cors": "^2.8.17"
  }
}
