{
  "name": "@satvaaah/admin",
  "version": "1.0.0",
  "description": "SatvAAh admin service \u2014 Admin portal, analytics, system config",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "start": "node dist/app.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@satvaaah/config": "workspace:*",
    "@satvaaah/db": "workspace:*",
    "@satvaaah/errors": "workspace:*",
    "@satvaaah/logger": "workspace:*",
    "@satvaaah/middleware": "workspace:*",
    "@satvaaah/types": "workspace:*",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0",
    "@aws-sdk/client-lambda": "^3.540.0",
    "@aws-sdk/client-sqs": "^3.540.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6"
  }
}