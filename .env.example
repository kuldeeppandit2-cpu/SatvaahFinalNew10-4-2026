# =============================================================================
# SatvAAh — Trust Layer for India's Informal Economy
# Environment Variables — Complete Reference
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================
# Hyderabad Launch | Zero Commission | India Informal Economy
# Maintained by: SatvAAh Engineering
# Last updated: 2026-04-03
# =============================================================================

# -----------------------------------------------------------------------------
# RUNTIME ENVIRONMENT
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
APP_NAME=SatvAAh
APP_URL=https://satvaaah.com
API_BASE_URL=https://api.satvaaah.com
SUPPORT_EMAIL=support@satvaaah.com

# -----------------------------------------------------------------------------
# SERVICE PORTS
# NOTE: Port 3008 is intentionally absent. No booking. No provider service.
# -----------------------------------------------------------------------------
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
SEARCH_SERVICE_PORT=3003
TRUST_SERVICE_PORT=3004
RATING_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
PAYMENT_SERVICE_PORT=3007
# 3008 — DOES NOT EXIST
ADMIN_SERVICE_PORT=3009
SCRAPING_SERVICE_PORT=3010
ADMIN_WEB_PORT=3099

# -----------------------------------------------------------------------------
# POSTGRESQL 15
# Primary relational store — users, trust scores, ratings, payments, verifs
# Container host: postgres | Port: 5432
# ORM: Prisma only (no Flyway, no raw SQL migrations outside Prisma)
# Migrations: packages/db/prisma/migrations/V001–V031 (V012 EXISTS = search_intents)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=satvaaah
POSTGRES_USER=satvaaah_user
POSTGRES_PASSWORD=S@tvAAh_PG_S3cur3_P@ssw0rd_2026!

# Prisma-compatible DATABASE_URL
DATABASE_URL=postgresql://satvaaah_user:S@tvAAh_PG_S3cur3_P@ssw0rd_2026!@postgres:5432/satvaaah?schema=public&connection_limit=10&pool_timeout=30

# Shadow database for Prisma migrate dev
SHADOW_DATABASE_URL=postgresql://satvaaah_user:S@tvAAh_PG_S3cur3_P@ssw0rd_2026!@postgres:5432/satvaaah_shadow?schema=public

# -----------------------------------------------------------------------------
# REDIS 7
# Sessions, rate limiting, pub/sub, distributed locks, caches
# Container host: satvaaah-redis | Port: 6379
# NOTE: Container name is "satvaaah-redis" (not "redis")
# -----------------------------------------------------------------------------
REDIS_HOST=satvaaah-redis
REDIS_PORT=6379
REDIS_PASSWORD=S@tvAAh_Redis_S3cur3_2026!
REDIS_URL=redis://:S@tvAAh_Redis_S3cur3_2026!@satvaaah-redis:6379
REDIS_TTL_DEFAULT=3600
REDIS_TTL_OTP=300
REDIS_TTL_SESSION=2592000
REDIS_TTL_SEARCH_CACHE=300

# -----------------------------------------------------------------------------
# MONGODB 7
# Unstructured data — activity feeds, chat logs, scraping results, audit trails
# Container host: mongodb | Port: 27017
# -----------------------------------------------------------------------------
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_ROOT_USER=satvaaah_mongo_root
MONGODB_ROOT_PASSWORD=S@tvAAh_Mongo_R00t_2026!
MONGODB_USER=satvaaah_mongo_user
MONGODB_PASSWORD=S@tvAAh_Mongo_S3cur3_2026!
MONGODB_DB=satvaaah_mongo
MONGODB_AUTH_SOURCE=admin
MONGODB_URL=mongodb://satvaaah_mongo_user:S@tvAAh_Mongo_S3cur3_2026!@mongodb:27017/satvaaah_mongo?authSource=admin&retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# OPENSEARCH 2.12
# Full-text search — provider discovery, service search, intent matching
# Container host: opensearch | Port: 9200
# SECURITY DISABLED IN DEV — enable before production deployment
# -----------------------------------------------------------------------------
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=S@tvAAh_OS_S3cur3_2026!
OPENSEARCH_INDEX_PROVIDERS=satvaaah_providers
OPENSEARCH_INDEX_SERVICES=satvaaah_services
OPENSEARCH_INDEX_SEARCH_INTENTS=satvaaah_search_intents

