# -----------------------------------------------------------------------------
# JWT — RS256 ASYMMETRIC SIGNING
# auth service signs with private key; all other services verify with public key
# Generate: openssl genrsa -out private.pem 4096 && openssl rsa -in private.pem -pubout -out public.pem
# Store full PEM with literal \n — DO NOT use file paths in Docker env
# POST /auth/firebase/verify REQUIRES consent_given: boolean (architecture rule)
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAKCAQEA... (paste full 4096-bit RSA private key with \n newlines) ...\n-----END RSA PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0B... (paste full RSA public key with \n newlines) ...\n-----END PUBLIC KEY-----\n"
JWT_ISSUER=https://api.satvaaah.com
JWT_AUDIENCE=satvaaah-app
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=30d
JWT_ALGORITHM=RS256

# Admin JWT (separate symmetric key for admin-web sessions — higher privilege)
ADMIN_JWT_SECRET=S@tvAAh_Adm1n_JWT_S3cr3t_128Bytes_2026_HyderabadLaunch!

