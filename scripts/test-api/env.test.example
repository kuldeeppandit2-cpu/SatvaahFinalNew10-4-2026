# SatvAAh API Test Environment
# Copy to .env.test and fill in values before running

FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccount.json
FIREBASE_API_KEY=AIzaSy...
FIREBASE_PROJECT_ID=satvaaah-dev

ADMIN_EMAIL=admin@satvaaah.com
ADMIN_PASSWORD=changeme

# PostgreSQL (must match docker-compose.yml)
PG_URL=postgresql://satvaaah:satvaaah@localhost:5432/satvaaah

# SQS — LocalStack for local dev
SQS_ENDPOINT=http://localhost:4566
SQS_REGION=ap-south-1
SQS_ACCOUNT_ID=000000000000

# Service ports (default: docker-compose.yml)
AUTH_PORT=3001
USER_PORT=3002
SEARCH_PORT=3003
TRUST_PORT=3004
RATING_PORT=3005
NOTIFICATION_PORT=3006
PAYMENT_PORT=3007
ADMIN_PORT=3009
