{
  "compilerOptions": {
    "target":         "ES2020",
    "module":         "CommonJS",
    "lib":            ["ES2020"],
    "strict":         true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir":         "./dist",
    "rootDir":        "./",
    "skipLibCheck":   true,
    "types":          ["node"]
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"]
}
