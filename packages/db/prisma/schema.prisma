// =============================================================================
// MODEL — ProviderAvailabilitySlots  (V050)
// Weekly recurring availability schedule per provider.
// Multiple rows per day allowed (split shifts e.g. 9am-12pm + 2pm-6pm).
// Available slots = this schedule MINUS provider_slot_exceptions
//                                  MINUS booked contact_events.slot_date
// =============================================================================
model ProviderAvailabilitySlot {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id String  @db.Uuid

  // 0=Sunday 1=Monday 2=Tuesday 3=Wednesday 4=Thursday 5=Friday 6=Saturday
  day_of_week Int
  start_time  String @db.VarChar(5) // HH:MM in Asia/Kolkata
  end_time    String @db.VarChar(5) // HH:MM in Asia/Kolkata. Must be > start_time.

  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  provider ProviderProfile @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([provider_id, day_of_week, start_time])
  @@index([provider_id, day_of_week, is_active])
  @@map("provider_availability_slots")
}

// =============================================================================
// MODEL — ProviderSlotException  (V050)
// Specific date overrides. Two modes:
//   is_available=false → provider is fully blocked that day (holiday etc.)
//   is_available=true  → extra hours beyond normal recurring schedule
// =============================================================================
model ProviderSlotException {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id String  @db.Uuid

  exception_date      DateTime @db.Date
  is_available        Boolean  // false=blocked, true=extra hours
  override_start_time String?  @db.VarChar(5) // HH:MM. Required if is_available=true.
  override_end_time   String?  @db.VarChar(5) // HH:MM. Required if is_available=true.
  note                String?  @db.VarChar(200)

  created_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  provider ProviderProfile @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([provider_id, exception_date])
  @@index([provider_id, exception_date])
  @@map("provider_slot_exceptions")
}
